        <rdfs:label xml:lang="it">Illustratore</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#LivelloComplessita -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#LivelloComplessita">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#Leggero"/>
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#Medio"/>
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#MedioLeggero"/>
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#MedioPesante"/>
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#Pesante"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Classe enumerata: l&apos;insieme chiuso delle cinque fasce di peso/complessita&apos; usate da BoardGameGeek.</rdfs:comment>
        <rdfs:label xml:lang="it">Livello di complessita&apos;</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Meccanica -->

