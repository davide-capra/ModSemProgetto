<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.unito.it/modsem/boardgames#"
     xml:base="http://www.unito.it/modsem/boardgames"
     xmlns:bg="http://www.unito.it/modsem/boardgames#"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:schema="http://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.unito.it/modsem/boardgames">
        <dc:creator xml:lang="it">[Nome Cognome]</dc:creator>
        <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-08</dc:date>
        <dc:description xml:lang="it">Ontologia che modella il dominio dei giochi da tavolo (tabletop games): giochi base ed espansioni, meccaniche di gioco, autori ed editori, componenti, livelli di complessita&apos; e sessioni di gioco. Pensata per task di consultazione di catalogo e raccomandazione, nello spirito di BoardGameGeek ma con semantica formale.</dc:description>
        <dc:title xml:lang="it">Ontologia per il catalogo e la raccomandazione di giochi da tavolo</dc:title>
        <dcterms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <vann:preferredNamespacePrefix>bg</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://www.unito.it/modsem/boardgames#</vann:preferredNamespaceUri>
        <rdfs:label xml:lang="it">Ontologia dei Giochi da Tavolo</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->

    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.unito.it/modsem/boardgames#eParteDi -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#eParteDi">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Componente"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#Componente"/>
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#Gioco"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="it">Proprieta&apos; transitiva di composizione: un componente puo&apos; essere parte di un altro componente o di un gioco; la transitivita&apos; propaga l&apos;appartenenza al gioco complessivo.</rdfs:comment>
        <rdfs:label xml:lang="it">e&apos; parte di</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#espande -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#espande">
        <owl:inverseOf rdf:resource="http://www.unito.it/modsem/boardgames#haEspansione"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Espansione"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#GiocoBase"/>
        <rdfs:comment xml:lang="it">Collega un&apos;espansione al gioco base che richiede ed estende.</rdfs:comment>
        <rdfs:label xml:lang="it">espande</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haCollaboratoCon -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haCollaboratoCon">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Autore"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Editore"/>
        <rdfs:comment xml:lang="it">Collega un autore a un editore con cui ha lavorato su almeno un gioco. Popolata dalla regola SWRL R5.</rdfs:comment>
        <rdfs:label xml:lang="it">ha collaborato con</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haComplessita -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haComplessita">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#LivelloComplessita"/>
        <rdfs:comment xml:lang="it">Proprieta&apos; funzionale: associa a ogni gioco un unico livello di complessita&apos; (fascia di peso BGG).</rdfs:comment>
        <rdfs:label xml:lang="it">ha complessita&apos;</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haComponente -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haComponente">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Componente"/>
        <rdfs:comment xml:lang="it">Collega un gioco a un componente fisico che ne fa parte.</rdfs:comment>
        <rdfs:label xml:lang="it">ha componente</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haEspansione -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haEspansione">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#GiocoBase"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Espansione"/>
        <rdfs:comment xml:lang="it">Proprieta&apos; inversa di &apos;espande&apos;: collega un gioco base alle sue espansioni.</rdfs:comment>
        <rdfs:label xml:lang="it">ha espansione</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haGiocato -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haGiocato">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Persona"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#partecipaA"/>
            <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#partitaDelGioco"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="it">Property chain: se una persona partecipa a una partita e quella partita e&apos; del gioco G, allora la persona ha giocato a G.</rdfs:comment>
        <rdfs:label xml:lang="it">ha giocato</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haMeccanica -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haMeccanica">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Meccanica"/>
        <rdfs:comment xml:lang="it">Collega un gioco a una delle sue meccaniche di gioco.</rdfs:comment>
        <rdfs:label xml:lang="it">ha meccanica</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haProgettato -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haProgettato">
        <owl:inverseOf rdf:resource="http://www.unito.it/modsem/boardgames#progettatoDa"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Autore"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Proprieta&apos; inversa di &apos;progettatoDa&apos;: collega un autore ai giochi che ha progettato.</rdfs:comment>
        <rdfs:label xml:lang="it">ha progettato</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#haVinto -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#haVinto">
        <rdfs:subPropertyOf rdf:resource="http://www.unito.it/modsem/boardgames#haGiocato"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Persona"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Collega una persona a un gioco di cui ha vinto almeno una partita. Popolata dalla regola SWRL R4 (sotto-proprieta&apos; di haGiocato).</rdfs:comment>
        <rdfs:label xml:lang="it">ha vinto</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#partecipaA -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#partecipaA">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Persona"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#PartitaGiocata"/>
        <rdfs:comment xml:lang="it">Collega un giocatore (persona) a una sessione di gioco a cui ha preso parte.</rdfs:comment>
        <rdfs:label xml:lang="it">partecipa a</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#partitaDelGioco -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#partitaDelGioco">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#PartitaGiocata"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Proprieta&apos; funzionale: collega una sessione di gioco all&apos;unico gioco a cui si e&apos; giocato.</rdfs:comment>
        <rdfs:label xml:lang="it">partita del gioco</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#progettatoDa -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#progettatoDa">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Autore"/>
        <rdfs:comment xml:lang="it">Collega un gioco all&apos;autore (game designer) che lo ha progettato.</rdfs:comment>
        <rdfs:label xml:lang="it">progettato da</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#pubblica -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#pubblica">
        <owl:inverseOf rdf:resource="http://www.unito.it/modsem/boardgames#pubblicatoDa"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Editore"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Proprieta&apos; inversa di &apos;pubblicatoDa&apos;: collega un editore ai giochi che pubblica.</rdfs:comment>
        <rdfs:label xml:lang="it">pubblica</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#pubblicatoDa -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#pubblicatoDa">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Editore"/>
        <rdfs:comment xml:lang="it">Collega un gioco all&apos;editore che lo ha pubblicato.</rdfs:comment>
        <rdfs:label xml:lang="it">pubblicato da</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#vintaDa -->

    <owl:ObjectProperty rdf:about="http://www.unito.it/modsem/boardgames#vintaDa">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#PartitaGiocata"/>
        <rdfs:range rdf:resource="http://www.unito.it/modsem/boardgames#Persona"/>
        <rdfs:comment xml:lang="it">Collega una sessione di gioco al giocatore che l&apos;ha vinta.</rdfs:comment>
        <rdfs:label xml:lang="it">vinta da</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.unito.it/modsem/boardgames#annoPubblicazione -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#annoPubblicazione">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:comment xml:lang="it">L&apos;anno in cui il gioco e&apos; stato pubblicato per la prima volta.</rdfs:comment>
        <rdfs:label xml:lang="it">anno di pubblicazione</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#dataPartita -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#dataPartita">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#PartitaGiocata"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="it">La data in cui si e&apos; svolta la sessione di gioco.</rdfs:comment>
        <rdfs:label xml:lang="it">data della partita</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#durataMediaMinuti -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#durataMediaMinuti">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">La durata media di una partita, espressa in minuti.</rdfs:comment>
        <rdfs:label xml:lang="it">durata media in minuti</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#etaConsigliata -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#etaConsigliata">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">L&apos;eta&apos; minima consigliata dall&apos;editore per giocare.</rdfs:comment>
        <rdfs:label xml:lang="it">eta&apos; consigliata</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#numeroMaxGiocatori -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#numeroMaxGiocatori">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Il numero massimo di giocatori supportato dal gioco.</rdfs:comment>
        <rdfs:label xml:lang="it">numero massimo di giocatori</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#numeroMinGiocatori -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#numeroMinGiocatori">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="it">Il numero minimo di giocatori richiesto per giocare.</rdfs:comment>
        <rdfs:label xml:lang="it">numero minimo di giocatori</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#titolo -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#titolo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="it">Il titolo ufficiale del gioco da tavolo.</rdfs:comment>
        <rdfs:label xml:lang="it">titolo</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.unito.it/modsem/boardgames#votoBGG -->

    <owl:DatatypeProperty rdf:about="http://www.unito.it/modsem/boardgames#votoBGG">
        <rdfs:domain rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="it">Il voto medio (da 1 a 10) assegnato dalla comunita&apos; di BoardGameGeek.</rdfs:comment>
        <rdfs:label xml:lang="it">voto BoardGameGeek</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/Game -->

    <owl:Class rdf:about="http://schema.org/Game">
        <rdfs:label xml:lang="en">Game</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Autore -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Autore">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Persona"/>
        <rdfs:comment xml:lang="it">Persona che progetta giochi da tavolo (game designer).</rdfs:comment>
        <rdfs:label xml:lang="it">Autore</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Carta -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Carta">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Componente"/>
        <owl:disjointWith rdf:resource="http://www.unito.it/modsem/boardgames#Dado"/>
        <rdfs:comment xml:lang="it">Una carta da gioco.</rdfs:comment>
        <rdfs:label xml:lang="it">Carta</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Componente -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Componente">
        <rdfs:comment xml:lang="it">Un elemento fisico che compone un gioco da tavolo.</rdfs:comment>
        <rdfs:label xml:lang="it">Componente</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Dado -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Dado">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Componente"/>
        <rdfs:comment xml:lang="it">Un dado usato per introdurre aleatorieta&apos;.</rdfs:comment>
        <rdfs:label xml:lang="it">Dado</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Editore -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Editore">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Organizzazione"/>
        <rdfs:comment xml:lang="it">Organizzazione che pubblica e distribuisce giochi da tavolo.</rdfs:comment>
        <rdfs:label xml:lang="it">Editore</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Espansione -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Espansione">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <owl:disjointWith rdf:resource="http://www.unito.it/modsem/boardgames#GiocoBase"/>
        <rdfs:comment xml:lang="it">Un gioco che estende un gioco base e ne richiede il possesso per essere giocato.</rdfs:comment>
        <rdfs:label xml:lang="it">Espansione</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Eurogame -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Eurogame">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#GiocoDiStrategia"/>
        <rdfs:comment xml:lang="it">Sottocategoria di gioco di strategia di stile europeo: poca aleatorieta&apos;, niente eliminazione, meccaniche gestionali.</rdfs:comment>
        <rdfs:label xml:lang="it">Eurogame</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Gioco -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Gioco">
        <rdfs:subClassOf rdf:resource="http://schema.org/Game"/>
        <rdfs:comment xml:lang="it">Classe radice del dominio: un gioco da tavolo. Allineata per sussunzione a schema:Game.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoAdattoBambini -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoAdattoBambini">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Gioco con eta&apos; consigliata non superiore a 8 anni. Popolata dalla regola SWRL R3.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco adatto ai bambini</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoAstratto -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoAstratto">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Gioco privo di tema narrativo, basato su pura logica o posizionamento (es. scacchi, go).</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco astratto</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoBase -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoBase">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Un gioco autonomo, giocabile senza richiedere altri prodotti.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco base</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoComplesso -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoComplesso">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#Gioco"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/modsem/boardgames#haMeccanica"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.unito.it/modsem/boardgames#Meccanica"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Classe definita (restrizione MIN): un gioco con almeno 3 meccaniche distinte. Il reasoner classifica qui i giochi idonei.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco complesso</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoConAleatorieta -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoConAleatorieta">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.unito.it/modsem/boardgames#Gioco"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.unito.it/modsem/boardgames#haMeccanica"/>
                        <owl:someValuesFrom rdf:resource="http://www.unito.it/modsem/boardgames#MeccanicaAleatoria"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Classe definita (restrizione SOME): un gioco che ha almeno una meccanica aleatoria. Il reasoner classifica qui i giochi idonei.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco con aleatorieta&apos;</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoDaGruppo -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoDaGruppo">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Gioco adatto a gruppi numerosi (almeno 6 giocatori). Popolata dalla regola SWRL R2.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco da gruppo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoDiSocieta -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoDiSocieta">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Gioco pensato per gruppi numerosi, con forte componente sociale e regole leggere.</rdfs:comment>
        <rdfs:label xml:lang="it">Party game</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoDiStrategia -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoDiStrategia">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Gioco in cui il risultato dipende prevalentemente dalle decisioni dei giocatori piu&apos; che dal caso.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco di strategia</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoLungo -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoLungo">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Gioco la cui durata media supera i 90 minuti. Popolata dalla regola SWRL R1.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco lungo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#GiocoPerFamiglie -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#GiocoPerFamiglie">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Gioco"/>
        <rdfs:comment xml:lang="it">Gioco con regole semplici e durata contenuta, adatto a giocatori di eta&apos; diverse.</rdfs:comment>
        <rdfs:label xml:lang="it">Gioco per famiglie</rdfs:label>
    </owl:Class>
    


    <!-- http://www.unito.it/modsem/boardgames#Illustratore -->

    <owl:Class rdf:about="http://www.unito.it/modsem/boardgames#Illustratore">
        <rdfs:subClassOf rdf:resource="http://www.unito.it/modsem/boardgames#Persona"/>
